{
  "name": "@agentdock/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first agent asset registry for managing and syncing skills and AGENTS.md assets.",
  "author": {
    "name": "AgentDock Contributors",
    "email": "[email protected]"
  },
  "license": "MIT",
  "homepage": "https://github.com/agentdock/AgentDock#readme",
  "main": "dist-electron/apps/desktop/src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:5173 dist-electron/apps/desktop/src/main/main.js dist-electron/apps/desktop/src/preload/preload.js && cross-env NODE_ENV=development electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "echo \"(no tests yet — add vitest/jest here)\" && exit 0",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^4.4.0",
    "fs-extra": "^11.3.5",
    "gray-matter": "^4.0.3",
    "jsdiff": "^1.1.1",
    "nanoid": "^5.1.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
